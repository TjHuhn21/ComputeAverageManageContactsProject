<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#7cfca9"
    tools:context=".ComputeAverage">

    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="INPUT GRADE"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:background="#abf7e4"
        android:gravity="center"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="150dp"
        android:layout_height="150dp"
        app:layout_constraintTop_toBottomOf="@id/textView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        tools:srcCompat="@drawable/heron"/>

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="2dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/imageView3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#c6cc7a"
        android:padding="12dp">

        <EditText
            android:id="@+id/etEnglish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="English Grade"
            android:inputType="numberDecimal"
            android:background="#e9f08d"
            android:textSize="18sp"
            android:minHeight="60dp"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etFilipino"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Filipino Grade"
            android:inputType="numberDecimal"
            android:background="#e9f08d"
            android:textSize="18sp"
            android:minHeight="60dp"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etMath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Math Grade"
            android:inputType="numberDecimal"
            android:background="#e9f08d"
            android:textSize="18sp"
            android:minHeight="60dp"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etScience"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Science Grade"
            android:inputType="numberDecimal"
            android:background="#e9f08d"
            android:textSize="18sp"
            android:minHeight="60dp"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etMAPEH"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="MAPEH Grade"
            android:inputType="numberDecimal"
            android:background="#e9f08d"
            android:textSize="18sp"
            android:minHeight="60dp"
            android:padding="12dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Back"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        android:layout_marginTop="10dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnSubmit"/>

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SUBMIT"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2E7D32"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toBottomOf="@id/inputContainer"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>